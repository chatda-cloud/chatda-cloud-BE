# ── FastAPI → DB ─────────────────────────────────────────────────────────────
# SQLAlchemy 비동기 DB 연결 문자열
# 형식: postgresql+asyncpg://<유저>:<비밀번호>@<호스트>:<포트>/<DB명>
# docker-compose 환경에서 호스트는 서비스명 "db" 사용
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/chatda

# ── PostgreSQL (docker-compose db 서비스) ────────────────────────────────────
# docker-compose의 db 컨테이너에 전달되는 초기 설정값
# DATABASE_URL의 유저/비밀번호/DB명과 반드시 일치해야 함
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=chatda

# ── JWT ──────────────────────────────────────────────────────────────────────
# JWT_SECRET: 토큰 서명에 사용하는 비밀키 — 배포 시 반드시 강력한 랜덤 값으로 교체
# ACCESS_TOKEN_EXPIRE_MINUTES: Access Token 만료 시간 (분)
# REFRESH_TOKEN_EXPIRE_DAYS: Refresh Token 만료 시간 (일)
# PW_RESET_BASE_URL: 비밀번호 재설정 이메일에 포함될 프론트엔드 URL
#   로컬: http://localhost:3000/reset-password
#   배포: https://your-domain.com/reset-password
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
PW_RESET_BASE_URL=

# ── AWS ──────────────────────────────────────────────────────────────────────
# S3 파일 업로드(프로필 사진 등)에 사용
# IAM 사용자의 액세스 키 발급 후 입력 (S3 권한 필요)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=
# CloudFront 도메인 (설정 시 이미지 조회 URL이 CDN 경유) — 미입력 시 S3 직접 URL 사용
CDN_BASE_URL=

# ── SMTP ─────────────────────────────────────────────────────────────────────
# 비밀번호 재설정 이메일 발송에 사용 (smtplib STARTTLS)
# Gmail 기준:
#   SMTP_HOST=smtp.gmail.com / SMTP_PORT=587
#   SMTP_USER: 발신 Gmail 주소 (KHU Google Workspace 메일도 사용 가능)
#   SMTP_PASSWORD: 앱 비밀번호 16자리
#     발급: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
#   SMTP_SENDER: 수신자에게 표시될 발신자 주소 (보통 SMTP_USER와 동일)
# SMTP_USER 또는 SMTP_PASSWORD가 비어 있으면 이메일 발송을 건너뜀 (개발 환경용)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=

# ── AI ───────────────────────────────────────────────────────────────────────
# Gemini API 키 — AI 태깅/분석 기능에 사용
GEMINI_API_KEY=

# ── 소셜 로그인 ───────────────────────────────────────────────────────────────
# 카카오 Developers → 내 애플리케이션 → 앱 키 → REST API 키
KAKAO_CLIENT_ID=
# 카카오 Developers → 카카오 로그인 → Redirect URI에 등록한 값과 동일해야 함
KAKAO_REDIRECT_URI=

# Google Cloud Console → API 및 서비스 → 사용자 인증 정보
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# 네이버 Developers → 애플리케이션 → Client ID / Secret
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=